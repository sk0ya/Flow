<UserControl x:Class="Flow.Views.Controls.GanttCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F8F9FA" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="FrozenCornerHeader"
                Grid.Row="0"
                Grid.Column="0"
                Background="#F2F4F8"
                BorderBrush="#C8CCD4"
                BorderThickness="0,0,1,1">
            <TextBlock Text="タスク"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5F6368"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Canvas x:Name="FrozenTimeHeaderCanvas"
                Grid.Row="0"
                Grid.Column="1"
                Background="#F2F4F8"
                ClipToBounds="True"/>

        <Canvas x:Name="FrozenLaneCanvas"
                Grid.Row="1"
                Grid.Column="0"
                Background="#F8F9FA"
                ClipToBounds="True"/>

        <ScrollViewer x:Name="TimelineScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#F8F9FA"
                      CanContentScroll="False">
            <Canvas x:Name="RootCanvas"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    ClipToBounds="False"/>
        </ScrollViewer>
    </Grid>
</UserControl>
