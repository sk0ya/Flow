<UserControl x:Class="Flow.Views.Controls.GanttCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="GanttLayoutGrid" Background="{DynamicResource AppSurfaceAltBrush}" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" MinWidth="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="FrozenCornerHeader"
                Grid.Row="0"
                Grid.Column="0"
                Background="{DynamicResource AppSurfaceMutedBrush}"
                BorderBrush="{DynamicResource AppBorderStrongBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="タスク"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <Canvas x:Name="FrozenTimeHeaderCanvas"
                Grid.Row="0"
                Grid.Column="1"
                Background="{DynamicResource AppSurfaceMutedBrush}"
                ClipToBounds="True"/>

        <Canvas x:Name="FrozenLaneCanvas"
                Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource AppSurfaceAltBrush}"
                ClipToBounds="True"/>

        <ScrollViewer x:Name="TimelineScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource AppSurfaceAltBrush}"
                      CanContentScroll="False">
            <Canvas x:Name="RootCanvas"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    ClipToBounds="False"/>
        </ScrollViewer>
    </Grid>
</UserControl>
