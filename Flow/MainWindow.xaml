<Window x:Class="Flow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Flow.ViewModels"
        xmlns:controls="clr-namespace:Flow.Views.Controls"
        Title="Flow"
        Icon="Assets/Flow.ico"
        Height="740" Width="1280"
        MinHeight="560" MinWidth="800"
        WindowStyle="None"
        Background="{DynamicResource AppWindowBackgroundBrush}" FontFamily="Segoe UI">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="Delete"             Command="{Binding DeleteSelectedItemCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddItemCommand}"/>
    </Window.InputBindings>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52"
                            ResizeBorderThickness="8"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Padding" Value="11,5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentOutlineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppAccentSubtleStrongBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppAccentTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentStrongBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource AppAccentHoverBrush}"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="{DynamicResource AppAccentPressedBrush}"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProjectIconBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSoftBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentOutlineBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentSubtleStrongBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleBarButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChipX" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="✕" FontSize="9" Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="PreChip" DataType="{x:Type vm:ConditionEntry}">
            <Border Margin="2" CornerRadius="12" Padding="2,0,7,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource AppInfoSurfaceBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource AppDangerSurfaceBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ToolTip><ToolTip Content="{Binding LinkDetail}"/></Border.ToolTip>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4" CornerRadius="2,0,0,2" Margin="0,2,6,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AppInfoBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource AppDangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Text="{Binding Value}" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppInfoBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource AppDangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Style="{StaticResource ChipX}" Foreground="{DynamicResource AppInfoBrush}"
                            Command="{Binding DataContext.RemovePreConditionCommand,
                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                            CommandParameter="{Binding}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PostChip" DataType="{x:Type vm:ConditionEntry}">
            <Border Margin="2" CornerRadius="12" Padding="2,0,7,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource AppSuccessSurfaceBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource AppNeutralSurfaceBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ToolTip><ToolTip Content="{Binding LinkDetail}"/></Border.ToolTip>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="4" CornerRadius="2,0,0,2" Margin="0,2,6,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AppSuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource AppNeutralBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Text="{Binding Value}" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource AppSuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLinked}" Value="False">
                                        <Setter Property="Foreground" Value="{DynamicResource AppNeutralBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Style="{StaticResource ChipX}" Foreground="{DynamicResource AppSuccessBrush}"
                            Command="{Binding DataContext.RemovePostConditionCommand,
                                RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                            CommandParameter="{Binding}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
        <Style x:Key="ActivityBtn" TargetType="RadioButton">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="ActivityBar"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bg" Background="Transparent"/>
                            <Border x:Name="Bar" Width="3" HorizontalAlignment="Left"
                                    Background="Transparent" CornerRadius="0,2,2,0"/>
                            <TextBlock x:Name="Ico"
                                       Text="{TemplateBinding Content}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppActivityBarIconBrush}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ico" Property="Foreground" Value="{DynamicResource AppInverseTextBrush}"/>
                                <Setter TargetName="Bar" Property="Background" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppActivityBarSelectedBackgroundBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppActivityBarHoverBrush}"/>
                                <Setter TargetName="Ico" Property="Foreground" Value="{DynamicResource AppActivityBarIconHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource InputComboBoxItem}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="▼"
                                           FontSize="9"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppTextMutedBrush}"/>
                            </Grid>
                            <ToggleButton x:Name="PART_ToggleButton"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Rectangle Fill="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="PART_ToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentOutlineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeOptionItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg"
                                Background="{DynamicResource AppSurfaceAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentOptionItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg"
                                Background="{DynamicResource AppSurfaceAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ════ TOOLBAR ════ -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0"
                            IsHitTestVisible="False">
                    <TextBlock Text="⬡" FontSize="20" Foreground="{DynamicResource AppAccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" Flow" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AppTextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ProjectName}"
                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="12,0" TextTrimming="CharacterEllipsis"
                           IsHitTestVisible="False"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <Border Background="{DynamicResource AppAccentSubtleBrush}" CornerRadius="8" Padding="10,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="プロジェクト期間  " FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ProjectDuration, StringFormat={}{0:0.####}}"
                                       FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AppAccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TimeUnit}" FontSize="11" Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppDangerSurfaceBrush}" CornerRadius="8" Padding="10,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasErrors}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="11" Foreground="{DynamicResource AppDangerBrush}">
                            <Run Text="⚠ "/>
                            <Run Text="{Binding Errors.Count, Mode=OneWay}"/>
                            <Run Text=" 件のエラー"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Style="{StaticResource TitleBarButton}" Click="OnMinimizeWindow" ToolTip="最小化">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE921;"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="OnToggleMaximizeWindow" ToolTip="最大化 / 元に戻す">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#xE922;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=WindowState}" Value="Maximized">
                                            <Setter Property="Text" Value="&#xE923;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Style="{StaticResource CloseTitleBarButton}" Click="OnCloseWindow" ToolTip="閉じる">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════ MAIN ════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="270" MinWidth="160" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── ACTIVITY BAR ── -->
            <Border Grid.Column="0" Background="{DynamicResource AppActivityBarBackgroundBrush}" BorderBrush="{DynamicResource AppActivityBarBorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">
                    <RadioButton Style="{StaticResource ActivityBtn}"
                                 Content="☰"
                                 IsChecked="{Binding IsProjectListActive, Mode=TwoWay}"
                                 ToolTip="プロジェクト"/>
                    <RadioButton Style="{StaticResource ActivityBtn}"
                                 Content="⚙"
                                 IsChecked="{Binding IsProjectSettingsActive, Mode=TwoWay}"
                                 ToolTip="プロジェクト設定"/>
                    <RadioButton Style="{StaticResource ActivityBtn}"
                                 Content="✏"
                                 IsChecked="{Binding IsTaskEditorActive, Mode=TwoWay}"
                                 ToolTip="タスク編集"/>
                    <RadioButton Style="{StaticResource ActivityBtn}"
                                 Content="☼"
                                 IsChecked="{Binding IsAppSettingsActive, Mode=TwoWay}"
                                 ToolTip="アプリ設定"/>
                </StackPanel>
            </Border>

            <!-- ── SIDEBAR ── -->
            <Grid Grid.Column="1" Background="{DynamicResource AppSurfaceBrush}">

                <!-- Panel: プロジェクト一覧 -->
                <Grid Visibility="{Binding IsProjectListActive, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                        <TextBlock Text="プロジェクト" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="12,12,12,8">
                        <Border Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="1" CornerRadius="10" Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Style="{StaticResource ProjectIconBtn}"
                                            Command="{Binding NewProjectCommand}"
                                            ToolTip="新しいプロジェクト"
                                            Content="&#xE710;"
                                            Margin="0,0,6,0"/>
                                    <Button Style="{StaticResource ProjectIconBtn}"
                                            Command="{Binding OpenProjectCommand}"
                                            ToolTip="プロジェクトを開く"
                                            Content="&#xE8E5;"
                                            Margin="0,0,6,0"/>
                                    <Button Style="{StaticResource ProjectIconBtn}"
                                            Command="{Binding SaveProjectCommand}"
                                            ToolTip="保存"
                                            Content="&#xE74E;"/>
                                </StackPanel>
                                <TextBlock Text="{Binding CurrentFilePath, TargetNullValue=未保存のプロジェクト}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                           Margin="0,10,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding CurrentFilePath}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Grid.Row="2" Margin="12,0" Padding="0,10"
                            BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="最近使ったファイル" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,0,0,6"/>
                            <ListBox ItemsSource="{Binding RecentProjects}"
                                     SelectedItem="{Binding SelectedRecentProject, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0">
                                <ListBox.Style>
                                    <Style TargetType="ListBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRecentProjects}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter Margin="{TemplateBinding Margin}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:RecentProjectEntry}">
                                        <Button Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Padding="10,8">
                                            <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource FlatBtn}">
                                                    <Setter Property="Margin" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding DirectoryPath}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="（なし）" FontSize="10" Foreground="{DynamicResource AppTextMutedBrush}" FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRecentProjects}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Panel: プロジェクト設定 -->
                <Grid Visibility="{Binding IsProjectSettingsActive, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                        <TextBlock Text="プロジェクト設定" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="12,12,12,0">
                        <TextBlock Text="プロジェクト名" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" FontSize="12"
                                 Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="時間単位" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,14,0,4"/>
                        <ComboBox ItemsSource="{x:Static vm:MainViewModel.TimeUnitOptions}"
                                  SelectedItem="{Binding TimeUnit}"
                                  Style="{StaticResource InputComboBox}"
                                  FontSize="12" VerticalContentAlignment="Center"/>
                        <TextBlock Text="全体期間" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,14,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource InputBox}" FontSize="12"
                                     Text="{Binding TotalDuration, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TimeUnit}" FontSize="11"
                                       Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                        <TextBlock Text="1マスあたりの時間" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,14,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource InputBox}" FontSize="12"
                                     Text="{Binding CellDurationText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Text="{Binding CellDurationUnitLabel}" FontSize="11"
                                       Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                        <TextBlock Text="{Binding CellDurationSummary}" FontSize="10" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,6,0,0"/>
                        <TextBlock Text="{Binding CellDurationError}" FontSize="10"
                                   Foreground="{DynamicResource AppDangerBrush}" Margin="0,4,0,0"
                                   Visibility="{Binding HasCellDurationError, Converter={StaticResource BoolVis}}"/>
                    </StackPanel>
                </Grid>

                <!-- Panel: アプリ設定 -->
                <Grid Visibility="{Binding IsAppSettingsActive, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                        <TextBlock Text="アプリ設定" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,12,12,16">
                            <TextBlock Text="カラーテーマ" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ListBox ItemsSource="{Binding ThemeOptions}"
                                     SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource ThemeOptionItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ThemeOption}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="10" Margin="0,3,0,0"
                                                       Foreground="{DynamicResource AppTextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="アクセントカラー" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,10,0,6"/>
                            <ListBox ItemsSource="{Binding AccentColorOptions}"
                                     SelectedItem="{Binding SelectedAccentColorOption, Mode=TwoWay}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource AccentOptionItem}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:AccentColorOption}">
                                        <StackPanel Width="62">
                                            <Border Width="22" Height="22"
                                                    Background="{Binding SwatchBrush}"
                                                    BorderBrush="{DynamicResource AppSurfaceBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="11"
                                                    HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontSize="9" Margin="0,6,0,0"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Margin="0,12,0,0"
                                    Padding="12"
                                    Background="{DynamicResource AppSurfaceAltBrush}"
                                    BorderBrush="{DynamicResource AppBorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="プレビュー" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                                    <Border Margin="0,8,0,0"
                                            Padding="10,8"
                                            Background="{DynamicResource AppAccentSubtleBrush}"
                                            CornerRadius="8">
                                        <DockPanel>
                                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AppAccentBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="変更はすぐに UI に反映されます"
                                                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Panel: タスク編集 -->
                <Grid Visibility="{Binding IsTaskEditorActive, Converter={StaticResource BoolVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add task -->
                    <Border Grid.Row="0" Background="{DynamicResource AppSurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="10,10">
                        <StackPanel>
                            <TextBlock Text="タスクを追加" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding NewItemName, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding AddItemCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="+ 追加" Style="{StaticResource PrimaryBtn}"
                                        Margin="5,0,0,0" Command="{Binding AddItemCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Editor header -->
                    <Border Grid.Row="1" Padding="10,6"
                            Background="{DynamicResource AppAccentSubtleBrush}" BorderBrush="{DynamicResource AppAccentOutlineBrush}" BorderThickness="0,0,0,1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AppAccentBrush}" VerticalAlignment="Center">
                                <Run Text="✏  "/>
                                <Run Text="{Binding SelectedItem.Name, Mode=OneWay, FallbackValue=''}"/>
                            </TextBlock>
                            <TextBlock Text="Delete で削除" FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <Border Grid.Row="2" Margin="16,30" Padding="14"
                            Background="{DynamicResource AppSurfaceAltBrush}" CornerRadius="10"
                            BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedItem}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="タスクを選択" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="ガントのバーをクリックすると編集できます"
                                       FontSize="10" Foreground="{DynamicResource AppTextMutedBrush}" TextWrapping="Wrap"
                                       Margin="0,5,0,0" TextAlignment="Center"/>
                            <TextBlock Text="バーをドラッグ → 時刻・レーン変更&#xa;右端をドラッグ → 長さ変更"
                                       FontSize="10" Foreground="{DynamicResource AppTextMutedBrush}" TextWrapping="Wrap"
                                       Margin="0,4,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Item editor -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  DataContext="{Binding SelectedItem}">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>

                        <StackPanel Margin="10,8,10,4">

                            <!-- Name -->
                            <TextBlock Text="名前" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" FontSize="13"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Timing row -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="開始" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" FontSize="12"
                                             Text="{Binding StartTime, StringFormat={}{0:0.####}, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="所要時間" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" FontSize="12"
                                             Text="{Binding Duration, StringFormat={}{0:0.####}, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Lane selector -->
                            <TextBlock Text="レーン" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,10,0,4"/>
                            <ComboBox ItemsSource="{Binding DataContext.Lanes, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding LaneId}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource InputComboBox}"
                                      FontSize="12"
                                      VerticalContentAlignment="Center"/>

                            <!-- Description -->
                            <TextBlock Text="説明（任意）" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,10,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" FontSize="11"
                                     Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" MaxLines="3" MinHeight="40" TextWrapping="Wrap"/>

                            <!-- Pre-conditions -->
                            <Grid Margin="0,10,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="事前条件" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppInfoBrush}" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource AppInfoSurfaceBrush}" CornerRadius="8" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding PreConditions.Count}" FontSize="9" Foreground="{DynamicResource AppInfoBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="開始前に必要" FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding PreConditions}" ItemTemplate="{StaticResource PreChip}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="PreCondInputBox" Style="{StaticResource InputBox}" FontSize="11"
                                         Text="{Binding NewPreCondition, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnPreCondInputChanged" LostFocus="OnCondInputLostFocus"
                                         PreviewKeyDown="OnCondInputKeyDown">
                                    <TextBox.InputBindings><KeyBinding Key="Return" Command="{Binding AddPreConditionCommand}"/></TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="追加" Margin="4,0,0,0"
                                        Style="{StaticResource FlatBtn}" FontSize="11" Padding="7,4"
                                        Command="{Binding AddPreConditionCommand}"/>
                            </Grid>

                            <!-- Post-conditions -->
                            <Grid Margin="0,10,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="事後条件" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource AppSuccessSurfaceBrush}" CornerRadius="8" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding PostConditions.Count}" FontSize="9" Foreground="{DynamicResource AppSuccessBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="完了後の状態" FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding PostConditions}" ItemTemplate="{StaticResource PostChip}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Grid Margin="0,4,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="PostCondInputBox" Style="{StaticResource InputBox}" FontSize="11"
                                         Text="{Binding NewPostCondition, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="OnPostCondInputChanged" LostFocus="OnCondInputLostFocus"
                                         PreviewKeyDown="OnCondInputKeyDown">
                                    <TextBox.InputBindings><KeyBinding Key="Return" Command="{Binding AddPostConditionCommand}"/></TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="1" Content="追加" Margin="4,0,0,0"
                                        Style="{StaticResource FlatBtn}" FontSize="11" Padding="7,4"
                                        Command="{Binding AddPostConditionCommand}"/>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Undo toast -->
                    <Border Grid.Row="3" Padding="12,8" Margin="8,4,8,6"
                            Background="{DynamicResource AppToastBackgroundBrush}" CornerRadius="8"
                            Visibility="{Binding CanUndoDelete, Converter={StaticResource BoolVis}}">
                        <Grid>
                            <TextBlock Text="{Binding UndoMessage}" Foreground="{DynamicResource AppInverseTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                            <Button Content="元に戻す" HorizontalAlignment="Right"
                                    FontSize="11" FontWeight="SemiBold"
                                    Foreground="{DynamicResource AppAccentBrush}" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Command="{Binding UndoDeleteCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="元に戻す" Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}" FontWeight="{TemplateBinding FontWeight}"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AppInverseTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <GridSplitter Grid.Column="2" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource AppBorderBrush}" Cursor="SizeWE"/>

            <!-- ── RIGHT: Gantt canvas ── -->
            <controls:GanttCanvas Grid.Column="3"
                                  x:Name="GanttView"
                                  ItemsSource="{Binding Items}"
                                  Edges="{Binding DependencyEdges}"
                                  SelectedItem="{Binding SelectedItem}"
                                  Lanes="{Binding Lanes}"
                                  TimeUnit="{Binding TimeUnit}"
                                  CellDuration="{Binding CellDuration}"
                                  TotalDuration="{Binding TotalDuration}"
                                  />
        </Grid>

        <!-- ════ ERROR PANEL ════ -->
        <Border Grid.Row="2" Background="{DynamicResource AppWarningSurfaceBrush}" BorderBrush="{DynamicResource AppWarningBorderBrush}" BorderThickness="0,1,0,0" MaxHeight="100">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasErrors}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Margin="14,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚠" FontSize="13" Foreground="{DynamicResource AppWarningBrush}" Margin="0,2,10,0" VerticalAlignment="Top"/>
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Errors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="11" Foreground="{DynamicResource AppWarningTextBrush}" Margin="0,2"
                                           Text="{Binding Message}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Suggestions popup -->
        <Popup x:Name="SuggestionsPopup" Grid.RowSpan="3"
               Placement="Bottom" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                    CornerRadius="8" MinWidth="200" MaxWidth="300">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Color="{DynamicResource AppPopupShadowColor}" Opacity="0.1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Border Background="{DynamicResource AppSurfaceAltBrush}" CornerRadius="8,8,0,0"
                            Padding="10,5" BorderBrush="{DynamicResource AppBorderSoftBrush}" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="SuggestionHeader" Text="候補"
                                   FontSize="10" Foreground="{DynamicResource AppTextMutedBrush}" FontWeight="SemiBold"/>
                    </Border>
                    <ListBox x:Name="SuggestionsListBox" MaxHeight="180" BorderThickness="0"
                             Background="Transparent" PreviewMouseDown="OnSuggestionClicked">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,7"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="B" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="B" Property="Background" Value="{DynamicResource AppAccentSubtleBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SuggestionItem}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}" FontSize="12" Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Source, StringFormat='  ← {0}'}"
                                               FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
